{
  "name": "deepseek-moby",
  "displayName": "DeepSeek Moby",
  "description": "Official DeepSeek AI assistant for VS Code with perfect formatting and chat history",
  "version": "1.0.0",
  "publisher": "deepseek",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Machine Learning",
    "AI"
  ],
  "keywords": [
    "deepseek",
    "ai",
    "chatgpt",
    "code completion",
    "programming",
    "assistant",
    "chat history"
  ],
  "icon": "media/moby.png",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:deepseek.startChat",
    "onView:deepseek-chat-view",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:cpp",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:php",
    "onLanguage:ruby",
    "onLanguage:csharp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "DeepSeek Moby",
      "properties": {
        "deepseek.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your DeepSeek API key (get from platform.deepseek.com)",
          "scope": "application"
        },
        "deepseek.model": {
          "type": "string",
          "default": "deepseek-chat",
          "enum": [
            "deepseek-chat",
            "deepseek-reasoner"
          ],
          "enumDescriptions": [
            "Standard chat model (DeepSeek-V3) - Fast, general purpose",
            "Reasoning model (DeepSeek-R1) - Shows chain-of-thought, better for complex problems"
          ],
          "description": "Which DeepSeek model to use"
        },
        "deepseek.enableCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completions"
        },
        "deepseek.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Creativity level (0=deterministic, 2=creative)"
        },
        "deepseek.maxToolCalls": {
          "type": "number",
          "default": 25,
          "minimum": 5,
          "maximum": 100,
          "description": "Maximum tool calling iterations per request. Each iteration can have multiple tool calls. (100=no limit, only applies to Chat model)"
        },
        "deepseek.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 256,
          "maximum": 65536,
          "description": "Maximum output tokens per response. Chat: up to 8K, Reasoner: up to 64K"
        },
        "deepseek.autoFormat": {
          "type": "boolean",
          "default": true,
          "description": "Automatically format code responses"
        },
        "deepseek.useLanguageFormatter": {
          "type": "boolean",
          "default": true,
          "description": "Use VS Code's language formatter after AI responses"
        },
        "deepseek.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show status bar with token usage"
        },
        "deepseek.maxHistorySessions": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum number of chat sessions to keep in history"
        },
        "deepseek.autoSaveHistory": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save chat history"
        },
        "deepseek.logLevel": {
          "type": "string",
          "default": "INFO",
          "enum": ["DEBUG", "INFO", "WARN", "ERROR", "OFF"],
          "enumDescriptions": [
            "Show all messages including debug info",
            "Show info, warnings and errors (default)",
            "Show warnings and errors only",
            "Show errors only",
            "Disable logging"
          ],
          "description": "Minimum log level to display in Output channel"
        },
        "deepseek.logColors": {
          "type": "boolean",
          "default": true,
          "description": "Enable color-coded log output"
        },
        "deepseek.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt to prepend to all requests (leave empty for default)",
          "editPresentation": "multilineText"
        },
        "deepseek.tavilyApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Tavily API key for web search (get from tavily.com)",
          "scope": "application"
        },
        "deepseek.tavilySearchesPerPrompt": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 20,
          "description": "Number of web searches allowed per prompt request"
        },
        "deepseek.tavilySearchDepth": {
          "type": "string",
          "default": "basic",
          "enum": [
            "basic",
            "advanced"
          ],
          "enumDescriptions": [
            "Basic search (1 credit per search)",
            "Advanced search with deeper content extraction (2 credits per search)"
          ],
          "description": "Tavily search depth mode"
        },
        "deepseek.editMode": {
          "type": "string",
          "default": "manual",
          "enum": [
            "manual",
            "ask",
            "auto"
          ],
          "enumDescriptions": [
            "Manual: Click Diff then Apply (current behavior)",
            "Ask: Auto-show diff and prompt for confirmation",
            "Auto: Automatically apply changes without asking (coming soon)"
          ],
          "description": "How to handle code edits from AI responses"
        },
        "deepseek.allowAllShellCommands": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Walk on the Wild Side**: Allow ALL shell commands for the Reasoner model (R1). Disables the safety blocklist that prevents catastrophic operations like `rm -rf /`. Only enable if you trust R1 completely.",
          "scope": "application"
        },
        "deepseek.devMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Developer Mode**: Enable dev tools for UI development. Shows a floating token editor panel (Ctrl+Shift+I) that allows real-time adjustment of spacing and style tokens across all shadow DOM components.",
          "scope": "window"
        }
      }
    },
    "commands": [
      {
        "command": "deepseek.startChat",
        "title": "DeepSeek Moby: Open Chat",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.explainCode",
        "title": "[Experimental] DeepSeek Moby: Explain This Code",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.refactorCode",
        "title": "[Experimental] DeepSeek Moby: Refactor This Code",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.documentCode",
        "title": "[Experimental] DeepSeek Moby: Add Documentation",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.fixBugs",
        "title": "[Experimental] DeepSeek Moby: Find and Fix Bugs",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.optimizeCode",
        "title": "[Experimental] DeepSeek Moby: Optimize Performance",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.generateTests",
        "title": "[Experimental] DeepSeek Moby: Generate Tests",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.clearConversation",
        "title": "Clear Chat",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.newChat",
        "title": "New Chat",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.insertCode",
        "title": "[Experimental] DeepSeek Moby: Insert Generated Code",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.switchModel",
        "title": "DeepSeek Moby: Switch Model",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.showChatHistory",
        "title": "DeepSeek Moby: Show Chat History",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.exportChatHistory",
        "title": "DeepSeek Moby: Export All Chat History",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.importChatHistory",
        "title": "DeepSeek Moby: Import Chat History",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.clearChatHistory",
        "title": "DeepSeek Moby: Clear All Chat History",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.searchChatHistory",
        "title": "DeepSeek Moby: Search Chat History",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.exportCurrentSession",
        "title": "DeepSeek Moby: Export Current Session",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.showStats",
        "title": "Statistics",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.showLogs",
        "title": "Show Log",
        "category": "DeepSeek Moby"
      },
      {
        "command": "deepseek.showDiffQuickPick",
        "title": "Show Pending Diffs",
        "category": "DeepSeek",
        "icon": "$(list-unordered)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "deepseek.explainCode",
          "when": "editorHasSelection",
          "group": "DeepSeek"
        },
        {
          "command": "deepseek.refactorCode",
          "when": "editorHasSelection",
          "group": "DeepSeek"
        },
        {
          "command": "deepseek.documentCode",
          "when": "editorHasSelection",
          "group": "DeepSeek"
        },
        {
          "command": "deepseek.fixBugs",
          "when": "editorHasSelection",
          "group": "DeepSeek"
        },
        {
          "command": "deepseek.optimizeCode",
          "when": "editorHasSelection",
          "group": "DeepSeek"
        }
      ],
      "commandPalette": [
        {
          "command": "deepseek.startChat",
          "when": "true"
        }
      ],
      "view/title": [
        {
          "command": "deepseek.newChat",
          "when": "view == deepseek-chat-view",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "deepseek.showDiffQuickPick",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "!editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deepseek-sidebar",
          "title": "DeepSeek Moby",
          "icon": "media/moby.png"
        }
      ]
    },
    "views": {
      "deepseek-sidebar": [
        {
          "type": "webview",
          "id": "deepseek-chat-view",
          "name": "Chat",
          "contextualTitle": "DeepSeek Moby Chat"
        }
      ]
    },
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      },
      {
        "language": "python",
        "path": "./snippets/python.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:media": "node scripts/build-media.js",
    "compile": "npm run build:media && webpack",
    "watch": "npm run build:media && webpack --watch",
    "package": "npm run build:media && webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "esbuild": "^0.19.12",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "happy-dom": "^15.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "vitest": "^2.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "events": "^3.3.0",
    "highlight.js": "^11.11.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deepseek-ai/deepseek-vscode.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/deepseek-ai/deepseek-vscode/issues"
  },
  "homepage": "https://github.com/deepseek-ai/deepseek-vscode#readme"
}
