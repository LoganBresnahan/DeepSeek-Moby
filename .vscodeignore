# === Source code (compiled to dist/) ===
src/**
scripts/**
packages/**

# === Media source (keep only the icon) ===
media/**
!media/moby.png

# === Tests & config ===
tests/**
test-results/**
playwright-report/**
playwright.config.*
vitest.config.*
tsconfig.json
webpack.config.js
package-lock.json
yarn.lock
.gitignore
.yarnrc
REMINDER.md
PLAN.md
CLAUDE.md
out/**
coverage/**

# === Documentation (not needed at runtime) ===
docs/**

# === IDE, CI & misc ===
.vscode/**
.vscode-test/**
.github/**
.claude/**
.tmp/**

# === TypeScript source (keep declarations) ===
*.ts
!*.d.ts

# === Source maps & license files in dist ===
dist/**/*.map
dist/**/*.LICENSE.txt

# === Legacy/dev files in dist ===
dist/media/dev/**
dist/media/history.*
dist/assets/tokenizer.json.br

# === Large preview/demo media (README loads via raw.githubusercontent URLs) ===
dist/media/*.gif
dist/media/*.mp4
media/*.gif
media/*.mp4

# === Node modules: exclude all except native addon + its runtime deps ===
# diff, uuid, deepseek-moby-wasm are bundled by webpack into dist/extension.js
# @signalapp/sqlcipher ships unbundled (native N-API addon with prebuilds).
# node-gyp-build is required at runtime by sqlcipher's index.cjs to locate
# the prebuild — without it, require('@signalapp/sqlcipher') throws
# `Cannot find module 'node-gyp-build'` and activation hangs/fails silently.
node_modules/**
!node_modules/@signalapp/**
!node_modules/node-gyp-build/**
