# === Source code (compiled to dist/) ===
src/**
scripts/**
packages/**

# === Media source (keep only the icon) ===
media/**
!media/moby.png

# === Tests & config ===
tests/**
test-results/**
playwright-report/**
playwright.config.*
vitest.config.*
tsconfig.json
webpack.config.js
package-lock.json
yarn.lock
.gitignore
.yarnrc
REMINDER.md
PLAN.md
CLAUDE.md
out/**
coverage/**

# === Documentation (not needed at runtime) ===
docs/**

# === IDE, CI & misc ===
.vscode/**
.vscode-test/**
.github/**
.claude/**
.tmp/**

# === TypeScript source (keep declarations) ===
*.ts
!*.d.ts

# === Source maps & license files in dist ===
dist/**/*.map
dist/**/*.LICENSE.txt

# === Legacy/dev files in dist ===
dist/media/dev/**
dist/media/history.*
dist/assets/tokenizer.json.br

# === Node modules: exclude all except native addon ===
# diff, uuid, deepseek-moby-wasm are bundled by webpack into dist/extension.js
# Only @signalapp/sqlcipher needs to ship (native N-API addon with prebuilds)
node_modules/**
!node_modules/@signalapp/**
